data/
checkpoints/
activations/
results/*.log
results/*.pt
__pycache__/
*.pyc

# Heavy artifact file types — must never be committed regardless of directory
*.npy
*.pt
*.pkl
*.h5
*.hdf5

# Fullstudy run storage (lives at /local/data/gme101/ on the cluster; guard against
# any local copies being accidentally staged).
# Note: features/ is a source code directory — the *.npy rule above blocks the
# heavy data files inside it; no directory-level ignore is needed.
manifests/*.pkl
plots/*.png
plots/*.pdf
logs/*.log
.ipynb_checkpoints/
